{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const f=JSON.parse(d)?.tool_input?.file_path;process.exit(f?.endsWith('.js')?0:1);})\" && npm test 2>&1 || true",
            "timeout": 60,
            "statusMessage": "Running unit tests..."
          }
        ]
      }
    ]
  }
}
